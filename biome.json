{
	"$schema": "https://biomejs.dev/schemas/2.3.11/schema.json",
	"files": {
		"includes": ["assets/**", "topics/**", "biome.json", "topics.json", "wrangler.json"]
	},
	"vcs": {
		"useIgnoreFile": true
	},
	"linter": {
		"enabled": false
	},
	"assist": {
		"enabled": false
	},
	"formatter": {
		"enabled": true,
		"lineWidth": 100,
		"indentStyle": "tab"
	},
	"html": {
		"formatter": {
			"enabled": true
		}
	}
}
